rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer usuário autenticado leia e grave apenas as suas próprias informações
    match /userdata/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permite que o próprio usuário salve e leia seus históricos e avaliações do questionário
      match /questionnaires/{questionnaireId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
